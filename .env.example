# Google Sheets Integration
# Sheet muss öffentlich lesbar sein (Freigabe → Jeder mit Link → Betrachter).
# Die Sheet-ID findest du in der URL: docs.google.com/spreadsheets/d/{SHEET_ID}/edit
# Spaltenreihenfolge im Sheet: ISIN | Ticker | Name | Currency | Quantity
# Erste Zeile = Header (wird übersprungen).
GOOGLE_SHEET_ID=
GOOGLE_SHEET_GID=0

# Mock-Modus erzwingen (kein Netzwerk nötig, z.B. für Tests)
USE_MOCK=
